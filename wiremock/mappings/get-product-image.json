{
  "mappings": [
    {
      "request": {
        "method": "GET",
        "urlPathPattern": "/products/[0-9]+/image"
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "image/jpeg",
          "Access-Control-Allow-Origin": "http://localhost:3001"
        },
        "bodyFileName": "fake-image.jpg"
      }
    }
  ]
}
